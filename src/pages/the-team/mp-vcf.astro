---
import Layout from '@layouts/Layout.astro';
import { SITE } from '../../lib/site';
const title = `MP vCard | ${SITE.name}`;
const description = 'Download contact card.';
---

<Layout title={title} description={description} canonical={`${SITE.url}/the-team/mp-vcf`} noindex={true}>
  <section class="mx-auto max-w-3xl px-4 py-16">
    <h1 class="text-3xl font-black text-global-blue">Download vCard</h1>
    <p class="mt-3 text-sm text-slate-600" id="status">Downloading contact card...</p>
    <div class="mt-6">
      <a class="inline-flex items-center justify-center rounded-lg bg-global-red px-5 py-3 text-sm font-semibold text-white hover:opacity-95"
         href="/vcards/mp.vcf" download>
        Download MP vCard
      </a>
    </div>

    <script>
      // Auto-trigger download on page load
      document.addEventListener('DOMContentLoaded', () => {
        const link = document.createElement('a');
        link.href = '/vcards/mp.vcf';
        link.download = 'Mark-Pauler.vcf';
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
        
        // Update status after brief delay
        setTimeout(() => {
          const statusEl = document.getElementById('status');
          if (statusEl) {
            statusEl.textContent = 'If your download didn\'t start, use the button below.';
          }
        }, 500);
      });
    </script>
  </section>
</Layout>
